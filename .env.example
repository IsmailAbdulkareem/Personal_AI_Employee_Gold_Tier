# Gold Tier AI Employee - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it's in .gitignore

# ============================================
# Facebook Configuration
# ============================================
FB_APP_ID=your_app_id_here
FB_APP_SECRET=your_app_secret_here
FB_ACCESS_TOKEN=your_page_access_token_here
FB_PAGE_ID=your_page_id_here
FB_VERSION=v18.0

# ============================================
# Instagram Configuration
# ============================================
IG_APP_ID=your_app_id_here
IG_APP_SECRET=your_app_secret_here
IG_ACCESS_TOKEN=your_page_access_token_here
IG_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here
IG_VERSION=v18.0

# ============================================
# Twitter/X Configuration
# ============================================
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_secret_here
TWITTER_BEARER_TOKEN=your_bearer_token_here

# ============================================
# Odoo Configuration
# ============================================
ODOO_URL=http://localhost:8069
ODOO_DB=gold_tier_accounting
ODOO_USERNAME=admin
ODOO_PASSWORD=your_admin_password_here
ODOO_API_KEY=your_generated_api_key_here

# ============================================
# Gmail Configuration
# ============================================
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:8080/callback

# ============================================
# LinkedIn Configuration
# ============================================
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here
LINKEDIN_ACCESS_TOKEN=your_access_token_here

# ============================================
# WhatsApp Configuration
# ============================================
WHATSAPP_PHONE_NUMBER=your_phone_number_here
WHATSAPP_SESSION_PATH=./watchers/.whatsapp_session

# ============================================
# General Configuration
# ============================================
VAULT_PATH=AI_Employee_Vault_Gold_Tier
NODE_ENV=development
